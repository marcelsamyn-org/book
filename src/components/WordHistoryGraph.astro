---
import type {
  PeriodBucket,
  PeriodKind,
  WordHistory,
} from "../publish/wordHistory.js";

interface Props {
  history: WordHistory;
  requiredDailyPace?: number;
  workRate?: number;
}

const { history, requiredDailyPace = 0, workRate = 1 } = Astro.props;

const VIEW_HEIGHT = 40;

/**
 * Multipliers for scaling the per-writing-day pace to week/month goal lines.
 * With workRate < 1 the lines reflect "per typical writing week/month"
 * rather than raw pace × 7 / pace × 30.
 */
const PACE_MULTIPLIER: Record<PeriodKind, number> = {
  day: 1,
  week: 7 * workRate,
  month: 30 * workRate,
};

interface SectionView {
  readonly kind: PeriodKind;
  readonly label: string;
  readonly buckets: readonly PeriodBucket[];
  readonly maxBarPos: number;
  readonly maxNeg: number;
  readonly zeroY: number;
  readonly span: number;
  readonly pace: number;
  readonly paceY: number;
}

const buildView = (
  kind: PeriodKind,
  label: string,
  buckets: readonly PeriodBucket[],
): SectionView => {
  const pace = Math.round(requiredDailyPace * PACE_MULTIPLIER[kind]);
  const maxBarPos = buckets.reduce((m, b) => Math.max(m, b.delta), 0);
  const scaleMax = Math.max(maxBarPos, pace);
  const maxNeg = buckets.reduce((m, b) => Math.max(m, -b.delta), 0);
  const span = scaleMax + maxNeg || 1;
  const zeroY = maxNeg > 0 ? (scaleMax / span) * VIEW_HEIGHT : VIEW_HEIGHT;
  const paceY = zeroY - (pace / span) * VIEW_HEIGHT;
  return {
    kind,
    label,
    buckets,
    maxBarPos,
    maxNeg,
    zeroY,
    span,
    pace,
    paceY,
  };
};

const sections: readonly SectionView[] = [
  buildView("day", "By day", history.day),
  buildView("week", "By week", history.week),
  buildView("month", "By month", history.month),
].filter((s) => s.buckets.length > 0);

const paceUnit: Record<PeriodKind, string> = {
  day: "day",
  week: "week",
  month: "month",
};
---

{sections.length > 0 && (
  <div class="word-history">
    {sections.map(({ kind, label, buckets, maxBarPos, maxNeg, zeroY, span, pace, paceY }) => {
      const n = buckets.length;
      const first = buckets[0]!;
      const last = buckets[n - 1]!;
      const statParts = [
        `${n} ${kind}s`,
        `max +${maxBarPos.toLocaleString("en-US")}${maxNeg > 0 ? ` / −${maxNeg.toLocaleString("en-US")}` : ""}`,
        ...(pace > 0 ? [`goal +${pace.toLocaleString("en-US")}/${paceUnit[kind]}`] : []),
      ];
      return (
        <div class="word-history-section">
          <div class="word-history-head">
            <span class="word-history-label">{label}</span>
            <span class="word-history-stat">{statParts.join(" · ")}</span>
          </div>
          <svg
            class="word-history-svg"
            viewBox={`0 0 ${n} ${VIEW_HEIGHT}`}
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            {maxNeg > 0 && (
              <line
                x1="0"
                x2={n}
                y1={zeroY}
                y2={zeroY}
                class="word-history-baseline"
              />
            )}
            {pace > 0 && (
              <line
                x1="0"
                x2={n}
                y1={paceY}
                y2={paceY}
                class="word-history-pace"
              />
            )}
            {buckets.map((b, i) => {
              if (b.delta === 0) return null;
              const h = (Math.abs(b.delta) / span) * VIEW_HEIGHT;
              const y = b.delta >= 0 ? zeroY - h : zeroY;
              return (
                <rect
                  x={i + 0.05}
                  y={y}
                  width={0.9}
                  height={h}
                  class={b.delta >= 0 ? "word-history-bar-pos" : "word-history-bar-neg"}
                />
              );
            })}
            {buckets.map((b, i) => (
              <rect
                x={i}
                y={0}
                width={1}
                height={VIEW_HEIGHT}
                class="word-history-hit"
                data-period-kind={kind}
                data-period-start={b.startIso}
                data-delta={b.delta}
              />
            ))}
          </svg>
          <div class="word-history-range">
            <span
              class="word-history-range-label"
              data-period-kind={kind}
              data-period-start={first.startIso}
            >{first.key}</span>
            <span class="word-history-range-sep">→</span>
            <span
              class="word-history-range-label"
              data-period-kind={kind}
              data-period-start={last.startIso}
            >{last.key}</span>
          </div>
        </div>
      );
    })}
    <div class="word-history-tooltip" role="tooltip" aria-hidden="true" hidden>
      <div class="word-history-tooltip-title"></div>
      <div class="word-history-tooltip-delta"></div>
    </div>
  </div>
)}

<script>
  const DAY_FMT = new Intl.DateTimeFormat(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
  const MONTH_FMT = new Intl.DateTimeFormat(undefined, {
    year: "numeric",
    month: "long",
  });

  function formatPeriod(kind: string, startIso: string): string {
    const date = new Date(`${startIso}T00:00:00`);
    if (kind === "month") return MONTH_FMT.format(date);
    if (kind === "week") return `Week of ${DAY_FMT.format(date)}`;
    return DAY_FMT.format(date);
  }

  function formatDelta(n: number): string {
    const sign = n > 0 ? "+" : n < 0 ? "−" : "";
    return `${sign}${Math.abs(n).toLocaleString()}`;
  }

  document
    .querySelectorAll<HTMLElement>(".word-history-range-label")
    .forEach((el) => {
      const kind = el.dataset["periodKind"];
      const start = el.dataset["periodStart"];
      if (!kind || !start) return;
      el.textContent = formatPeriod(kind, start);
    });

  const tooltip = document.querySelector<HTMLElement>(".word-history-tooltip");
  const titleEl = tooltip?.querySelector<HTMLElement>(
    ".word-history-tooltip-title",
  );
  const deltaEl = tooltip?.querySelector<HTMLElement>(
    ".word-history-tooltip-delta",
  );

  if (tooltip && titleEl && deltaEl) {
    const hits = document.querySelectorAll<SVGRectElement>(
      ".word-history-hit",
    );

    const showAt = (target: SVGRectElement, clientX: number, clientY: number) => {
      const kind = target.dataset["periodKind"];
      const start = target.dataset["periodStart"];
      if (!kind || !start) return;
      const delta = parseInt(target.dataset["delta"] ?? "0", 10);
      titleEl.textContent = formatPeriod(kind, start);
      deltaEl.textContent = delta === 0 ? "no change" : `${formatDelta(delta)} words`;
      tooltip.hidden = false;
      const pad = 12;
      const w = tooltip.offsetWidth;
      const h = tooltip.offsetHeight;
      const flipX = clientX + pad + w > window.innerWidth;
      const flipY = clientY + pad + h > window.innerHeight;
      tooltip.style.left = `${flipX ? clientX - w - pad : clientX + pad}px`;
      tooltip.style.top = `${flipY ? clientY - h - pad : clientY + pad}px`;
    };

    hits.forEach((hit) => {
      hit.addEventListener("mouseenter", (e) => showAt(hit, e.clientX, e.clientY));
      hit.addEventListener("mousemove", (e) => showAt(hit, e.clientX, e.clientY));
      hit.addEventListener("mouseleave", () => {
        tooltip.hidden = true;
      });
    });
  }
</script>

<style>
  .word-history {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .word-history-section {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .word-history-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
  }

  .word-history-label {
    color: var(--ink-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .word-history-stat {
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .word-history-svg {
    width: 100%;
    height: 44px;
    display: block;
  }

  .word-history-bar-pos {
    fill: var(--ink-secondary);
  }

  .word-history-bar-neg {
    fill: var(--accent);
    opacity: 0.55;
  }

  .word-history-baseline {
    stroke: var(--rule);
    stroke-width: 1px;
    vector-effect: non-scaling-stroke;
  }

  .word-history-pace {
    stroke: var(--accent);
    stroke-width: 1px;
    stroke-dasharray: 3 3;
    opacity: 0.7;
    vector-effect: non-scaling-stroke;
  }

  .word-history-range {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
  }

  .word-history-range-sep {
    opacity: 0.4;
  }

  .word-history-hit {
    fill: transparent;
    pointer-events: all;
    cursor: crosshair;
    transition: fill 0.1s ease;
  }

  .word-history-hit:hover {
    fill: var(--ink);
    fill-opacity: 0.07;
  }

  .word-history-tooltip {
    position: fixed;
    z-index: 50;
    pointer-events: none;
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--rule);
    border-radius: 0.25rem;
    padding: 0.4rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    line-height: 1.45;
    box-shadow: 0 2px 10px color-mix(in srgb, var(--ink) 18%, transparent);
    max-width: 16rem;
  }

  .word-history-tooltip[hidden] {
    display: none;
  }

  .word-history-tooltip-title {
    color: var(--ink);
    font-weight: 500;
  }

  .word-history-tooltip-delta {
    color: var(--ink-muted);
    font-variant-numeric: tabular-nums;
    margin-top: 0.15rem;
  }
</style>
